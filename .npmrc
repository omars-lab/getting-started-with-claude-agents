# @omars-lab/blog-ui is published to GitHub Packages (see the publish-blog-ui skill in the
# blog repo). Installing it requires a GitHub token with read:packages in the environment.
#   export GITHUB_TOKEN=$(gh auth token)   # or a PAT with read:packages
# The token is read from the env at install time — it is NOT stored in this file.
@omars-lab:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
